    "@tanstack/react-table": "^8.21.3",
    "@xyflow/react": "^12.10.0",
    "aws-svg-icons": "^3.0.0-2021-07-30",
    "ajv": "^8.17.1",
    "clsx": "^2.1.1",
    "fast-xml-parser": "^4.5.0",
    "framer-motion": "^12.26.2",
    "html-to-image": "^1.11.13",
    "html2pdf.js": "^0.14.0",
    "lucide-react": "^0.562.0",
    "next": "16.1.2",
