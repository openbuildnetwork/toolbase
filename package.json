{
  "name": "toolbase",
  "description": "Every tool you need. Zero data leaves your machine.",
  "type": "module",
  "version": "0.1.0",
  "license": "MIT",
  "author": "Toolbase Contributors",
  "private": true,
  "scripts": {
    "start": "next start",
    "build:python": "node scripts/build-python-bundler.mjs",
    "build:archive-kit:wasm": "wasm-pack build rust/archive-kit --target web --out-dir ../../public/wasm/archive-kit/pkg",
    "build:wasm": "node scripts/build-wasm.mjs",
    "check:wasm": "node scripts/check-wasm-artifacts.mjs",
    "watch:python": "nodemon --watch src/python -e py --exec \"npm run build:python\"",
    "watch:wasm": "nodemon --watch rust -e rs,toml --exec \"npm run build:wasm -- --dev\"",
    "build": "npm run build:python && npm run build:wasm && next build",
    "build:strict-wasm": "npm run build:python && npm run build:wasm && npm run check:wasm && next build",
    "dev": "concurrently \"npm run watch:python\" \"npm run watch:wasm\" \"next dev --turbo\"",
    "lint": "eslint",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@iarna/toml": "^2.2.5",
    "@mlc-ai/web-llm": "^0.2.83",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-table": "^8.21.3",
    "@types/marked": "^5.0.2",
    "@xyflow/react": "^12.10.0",
    "aws-svg-icons": "^3.0.0-2021-07-30",
    "clsx": "^2.1.1",
    "fast-xml-parser": "^5.4.2",
    "framer-motion": "^12.26.2",
    "html-to-image": "^1.11.13",
    "html2pdf.js": "^0.14.0",
    "idb": "^8.0.3",
    "jspdf": "^4.1.0",
    "lucide-react": "^0.562.0",
    "marked": "^18.0.3",
    "next": "16.1.2",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.530",
    "pyodide": "^0.29.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-virtualized-auto-sizer": "^2.0.2",
    "react-window": "^2.2.5",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.30",
    "@types/pdfjs-dist": "^2.10.377",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bzip2": "^0.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.2",
    "nodemon": "^3.1.11",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tar": "^7.5.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
