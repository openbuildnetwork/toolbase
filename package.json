{
  "name": "tool-box",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "next start",
    "build:python": "ts-node scripts/build-python-bundler.ts",
    "watch:python": "nodemon --watch src/python -e py --exec \"npm run build:python\"",
